{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "dist-server",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "useDefineForClassFields": false,
    "baseUrl": "."
  },
  "include": ["backend/**/*.ts", "src/entities/**/*.ts"]
}